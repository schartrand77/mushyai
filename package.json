{
  "name": "mushyai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "check": "npm run lint && npm run format:check && npm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:docker": "docker compose -p mushyai-e2e -f docker-compose.e2e.yml up --build --abort-on-container-exit --exit-code-from playwright",
    "test:e2e:docker:down": "docker compose -p mushyai-e2e -f docker-compose.e2e.yml down -v --remove-orphans"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@playwright/test": "^1.51.1",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.3",
    "vite": "^6.2.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1"
  }
}
